{
  "version": 1,
  "path_rules": [
    {"path": "/v1/chat", "methods": ["POST"], "require_auth": false},
    {"path": "/v1/architect/invoke", "methods": ["POST"], "require_auth": false},
    {"path": "/v1/governor/", "methods": ["GET", "POST", "PUT"], "require_auth": false},
