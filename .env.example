# HarmonClaw Environment Variables
# Copy to .env and customize

HC_PORT=8080
HC_DATA_DIR=
HC_LOG_LEVEL=info
HC_AUTH_ENABLED=false
HC_JWT_SECRET=
HC_SOVEREIGNTY_MODE=airlock
HC_CONFIG=configs/config.json
HC_IRONCLAW_POLICIES=configs/policies.json

DEEPSEEK_API_KEY=
BRAVE_API_KEY=
HC_BRAVE_CONFIG=
# Optional: override Brave API host for integration tests only (default https://api.search.brave.com)
# HC_BRAVE_API_BASE=
HC_TTS_ENDPOINT=
HC_SEARCH_API=
HC_OPENCLAW_ENDPOINT=
HC_MIMICCLAW_ENDPOINT=
HC_NANOCLAW_ENDPOINT=
HC_PICOCLAW_ENDPOINT=
